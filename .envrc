use flake

# Reuses the infra (terraform) tailscale OAuth client; replace with a
# rotate-scoped client at infra/tailscale/kradalby/rotate-oauth/* if needed.
secret_env -v <<'SECRETS'
  TS_ROTATE_CLIENT_ID      infra/tailscale/kradalby/oauth/client-id
  TS_ROTATE_CLIENT_SECRET  infra/tailscale/kradalby/oauth/client-secret
SECRETS
export TS_ROTATE_DOMAIN=kradalby.no

source_env_if_exists .envrc.local
