{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-claude-auth@latest"
  ],
  "permission": {
    "external_directory": {
      "~/go/**": "allow",
      "~/git/**": "allow",
      "/nix/**": "allow",
      "/tmp/**": "allow",
      "/private/tmp/**": "allow"
    },
    "edit": {
      "~/go/**": "deny",
      "~/git/**": "deny",
      "/nix/**": "deny"
    }
  }
}
