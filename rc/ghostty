# theme = Mathias
# theme = light:OneHalfLight,dark:ayu
theme = ayu
background = 000000
font-size = 11

# Window
window-decoration = true
window-padding-x = 0
window-padding-y = 0
window-save-state = never
copy-on-select = clipboard
unfocused-split-opacity = 0.97
mouse-hide-while-typing = true

# macOS
macos-titlebar-style = tabs
macos-window-shadow = false
macos-titlebar-proxy-icon = hidden
macos-secure-input-indication = false

# Window/tab management uses Ghostty's standard keybinds. boo sessions are
# single-window; juggle multiple with `boo ui` or Ghostty tabs.

# Command done notifications (replaces fish done plugin)
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

# Remote tab: open new tab + mosh to dev.ldn.fap.no
# TODO(ghostty): Workaround for Ghostty lacking an exec/command keybind action.
# The cmd+shift+t hotkey is handled by skhd (see common/darwin/kradalby-base.nix)
# which runs bin/ghostty-new-mosh-tab using ghostty-tab to open a new tab via AppleScript.
# This unbind prevents Ghostty from intercepting the keystroke before skhd sees it.
# Ref: https://github.com/ghostty-org/ghostty/issues/9961
# Ref: https://github.com/ghostty-org/ghostty/discussions/10919
# Remove this workaround when Ghostty supports an exec keybind action.
keybind = cmd+shift+t=unbind
